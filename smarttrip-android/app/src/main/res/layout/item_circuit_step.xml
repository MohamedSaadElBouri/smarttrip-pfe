<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:layout_marginBottom="12dp">

    <!-- Step indicator column -->
    <LinearLayout
        android:layout_width="48dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Step circle -->
        <TextView
            android:id="@+id/tvStepNumber"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:textColor="@color/on_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/gradient_primary"
            tools:text="1" />

        <!-- Vertical line (connecting steps) -->
        <View
            android:id="@+id/vStepLine"
            android:layout_width="2dp"
            android:layout_height="match_parent"
            android:layout_gravity="center_horizontal"
            android:minHeight="24dp"
            android:background="@color/outline" />

    </LinearLayout>

    <!-- Step content -->
    <androidx.cardview.widget.CardView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="8dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="1dp"
        app:cardBackgroundColor="@color/surface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- Time + Place name row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvStepTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/primary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:background="#1AD62839"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    tools:text="09:00" />

                <TextView
                    android:id="@+id/tvStepDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:textColor="@color/charcoal"
                    android:textSize="11sp"
                    tools:text="90 min" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvStepPlaceName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/on_surface"
                android:textSize="15sp"
                android:textStyle="bold"
                tools:text="Medersa Bou Inania" />

            <TextView
                android:id="@+id/tvStepPlaceCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/charcoal"
                android:textSize="12sp"
                tools:text="Patrimoine · Fès" />

            <TextView
                android:id="@+id/tvStepNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/charcoal"
                android:textSize="13sp"
                android:textStyle="italic"
                android:visibility="gone"
                tools:text="Prévoir 1h30 minimum pour explorer..." />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".ui.exploration.CatalogueLieuxActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/gradient_primary"
        app:title="Explorer les Lieux"
        app:titleTextColor="@color/on_primary"
        app:navigationIconTint="@color/on_primary"
        app:subtitle="Découvrez le Maroc"
        app:subtitleTextColor="#CCFFFFFF"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Filter chips -->
    <HorizontalScrollView
        android:id="@+id/scrollViewFilters"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp"
        android:scrollbars="none"
        android:background="@color/surface"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌍 Tous"
                android:checkable="true"
                android:checked="true"
                android:layout_marginEnd="6dp"
                style="@style/Widget.MaterialComponents.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipMonuments"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏛️ Monuments"
                android:checkable="true"
                android:layout_marginEnd="6dp"
                style="@style/Widget.MaterialComponents.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipNature"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌿 Nature"
                android:checkable="true"
                android:layout_marginEnd="6dp"
                style="@style/Widget.MaterialComponents.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipResto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎨 Artisanat"
                android:checkable="true"
                android:layout_marginEnd="6dp"
                style="@style/Widget.MaterialComponents.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipRestaurants"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🍽️ Restaurants"
                android:checkable="true"
                android:layout_marginEnd="6dp"
                style="@style/Widget.MaterialComponents.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipHotels"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏨 Hôtels"
                android:checkable="true"
                android:layout_marginEnd="6dp"
                style="@style/Widget.MaterialComponents.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipActivites"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏄 Activités"
                android:checkable="true"
                style="@style/Widget.MaterialComponents.Chip.Choice" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Thin divider -->
    <View
        android:id="@+id/dividerFilters"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/outline"
        app:layout_constraintTop_toBottomOf="@id/scrollViewFilters" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewLieux"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingHorizontal="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/dividerFilters"
        app:layout_constraintBottom_toBottomOf="parent" />

    <ProgressBar
        android:id="@+id/progressLieux"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="@color/primary"
        app:layout_constraintTop_toBottomOf="@id/dividerFilters"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/layoutLieuxEmpty"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        android:padding="40dp"
        app:layout_constraintTop_toBottomOf="@id/dividerFilters"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏛️"
            android:textSize="56sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Aucun lieu trouvé"
            android:textColor="@color/on_surface"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="Essayez un autre filtre pour explorer plus de lieux."
            android:textColor="@color/charcoal"
            android:textSize="14sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp">

    <ImageView
        android:id="@+id/ivCommentAvatar"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/circle_avatar_bg"
        android:scaleType="centerCrop"
        android:clipToOutline="true"
        android:layout_marginTop="2dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp"
        android:background="@drawable/bg_comment_bubble"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvCommentAuthor"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textStyle="bold"
                android:textColor="@color/on_surface"
                android:textSize="13sp"
                android:text="Nom Auteur" />

            <TextView
                android:id="@+id/tvCommentDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/charcoal"
                android:textSize="11sp"
                android:text="Il y a 2h" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvCommentContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/on_surface"
            android:textSize="14sp"
            android:lineSpacingExtra="2dp"
            android:text="Commentaire..." />

    </LinearLayout>

</LinearLayout>

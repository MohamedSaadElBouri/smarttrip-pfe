<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvTripTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Titre du Circuit"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/on_surface" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🗺️"
                android:textSize="22sp"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvTripDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Description..."
            android:layout_marginTop="8dp"
            android:textColor="@color/charcoal"
            android:textSize="14sp"
            android:lineSpacingExtra="3dp"
            android:maxLines="3"
            android:ellipsize="end" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <TextView
                android:id="@+id/tvTripDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏱ 3 Jours"
                android:background="@drawable/rounded_bg_gray"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp"
                android:textColor="@color/on_surface"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tvTripBudget"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💰 1500 MAD"
                android:background="@drawable/rounded_bg_gray"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp"
                android:textColor="@color/on_surface"
                android:textSize="12sp"
                android:textStyle="bold" />

        </LinearLayout>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupCategories"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:chipSpacingHorizontal="6dp"
            app:chipSpacingVertical="4dp" />

        <LinearLayout
            android:id="@+id/layoutReason"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_reason_box"
            android:padding="14dp"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💡"
                android:textSize="18sp"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/tvTripReason"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Pourquoi ce circuit vous est recommandé"
                android:textColor="@color/primary_container"
                android:textSize="13sp"
                android:lineSpacingExtra="2dp"
                android:textStyle="italic" />
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>

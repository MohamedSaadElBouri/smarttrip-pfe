<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true"
    tools:context=".ui.questionnaire.QuestionnaireActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="24dp"
            android:paddingTop="28dp"
            android:paddingBottom="20dp"
            android:background="@drawable/gradient_primary">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mon Voyage Idéal"
                android:textColor="@color/on_primary"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Répondez à ces questions pour que l'IA génère votre circuit sur-mesure."
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"
                android:gravity="center_horizontal" />

        </LinearLayout>

        <!-- Form Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- ===== Section: À propos de vous ===== -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp"
                android:text="À PROPOS DE VOUS"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilNationality"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Nationalité (ex: France)"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp">

                        <AutoCompleteTextView
                            android:id="@+id/etNationality"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView style="@style/QuestionLabel" android:text="Tranche d'âge" />
                    <Spinner android:id="@+id/spinnerAgeGroup" style="@style/QuestionSpinner" />

                    <TextView style="@style/QuestionLabel" android:text="Genre" />
                    <Spinner android:id="@+id/spinnerGender" style="@style/QuestionSpinner" />

                    <TextView style="@style/QuestionLabel" android:text="Avez-vous déjà visité le Maroc ?" />
                    <Spinner android:id="@+id/spinnerHasVisited" style="@style/QuestionSpinner" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== Section: Votre groupe ===== -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="12dp"
                android:text="VOTRE GROUPE"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView style="@style/QuestionLabel" android:text="Type de groupe" />
                    <Spinner android:id="@+id/spinnerGroupType" style="@style/QuestionSpinner" />

                    <TextView style="@style/QuestionLabel" android:text="Taille du groupe" />
                    <Spinner android:id="@+id/spinnerGroupSize" style="@style/QuestionSpinner" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== Section: Style de voyage ===== -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="12dp"
                android:text="STYLE DE VOYAGE"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView style="@style/QuestionLabel" android:text="Niveau de budget" />
                    <Spinner android:id="@+id/spinnerBudget" style="@style/QuestionSpinner" />

                    <TextView style="@style/QuestionLabel" android:text="Durée du séjour" />
                    <Spinner android:id="@+id/spinnerDuration" style="@style/QuestionSpinner" />

                    <TextView style="@style/QuestionLabel" android:text="Style de voyage" />
                    <Spinner android:id="@+id/spinnerStyle" style="@style/QuestionSpinner" />

                    <TextView style="@style/QuestionLabel" android:text="Niveau d'activité souhaité" />
                    <Spinner android:id="@+id/spinnerActivityLevel" style="@style/QuestionSpinner" />

                    <TextView style="@style/QuestionLabel" android:text="Ambiance préférée" />
                    <Spinner android:id="@+id/spinnerNoise" style="@style/QuestionSpinner" />

                    <TextView style="@style/QuestionLabel" android:text="Saison préférée" />
                    <Spinner android:id="@+id/spinnerSeason" style="@style/QuestionSpinner" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== Section: Centres d'intérêt ===== -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="12dp"
                android:text="CENTRES D'INTÉRÊT"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="Sélectionnez tout ce qui vous intéresse"
                        android:textColor="@color/charcoal"
                        android:textSize="13sp" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupInterests"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:singleSelection="false">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipHistory"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:text="🏛️ Histoire" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipNature"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:text="🌿 Nature" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipFood"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:text="🍽️ Gastronomie" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipAdventure"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="false"
                            android:text="🧗 Aventure" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipPhotography"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:text="📷 Photographie" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipWellness"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="false"
                            android:text="🧘 Bien-être" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipShopping"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="false"
                            android:text="🛍️ Shopping" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipFestivals"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:text="🎭 Festivals" />

                    </com.google.android.material.chip.ChipGroup>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== Section: Logistique ===== -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="12dp"
                android:text="LOGISTIQUE"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView style="@style/QuestionLabel" android:text="Préférence alimentaire" />
                    <Spinner android:id="@+id/spinnerFood" style="@style/QuestionSpinner" />

                    <TextView style="@style/QuestionLabel" android:text="Hébergement préféré" />
                    <Spinner android:id="@+id/spinnerAccommodation" style="@style/QuestionSpinner" />

                    <TextView style="@style/QuestionLabel" android:text="Transport préféré" />
                    <Spinner android:id="@+id/spinnerTransport" style="@style/QuestionSpinner" />

                    <TextView style="@style/QuestionLabel" android:text="Besoins spécifiques" />
                    <Spinner android:id="@+id/spinnerSpecialNeeds" style="@style/QuestionSpinner" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Generate Button — extra bottom margin to clear navigation bar -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGenerate"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="96dp"
                android:text="✨  Générer mon voyage avec l'IA"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="28dp"
                android:backgroundTint="@color/primary" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>

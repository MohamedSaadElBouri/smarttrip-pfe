<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:windowSoftInputMode="adjustResize"
        android:theme="@style/Theme.SmartTripVoyager">
        <activity
            android:name=".ui.auth.SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <activity android:name=".ui.auth.LoginActivity" />
        <activity android:name=".ui.auth.RegisterActivity" />
        <activity android:name=".ui.auth.SetupActivity" />
        <activity android:name=".ui.home.HomeActivity" />
        <activity android:name=".ui.home.CreatePostActivity" />
        <activity android:name=".ui.questionnaire.QuestionnaireActivity" />
        <activity android:name=".ui.questionnaire.LoadingAiActivity" />
        <activity android:name=".ui.questionnaire.ResultAiActivity" />
        <activity android:name=".ui.questionnaire.GeneratedTripsActivity" />
        <activity android:name=".ui.home.CommentsActivity" />
        <activity android:name=".ui.home.MyTripsActivity" />
        <activity android:name=".ui.circuit.CircuitDetailActivity" />
        <activity android:name=".ui.exploration.CatalogueLieuxActivity" />
        <activity android:name=".ui.exploration.LieuDetailActivity" />
        <activity android:name=".ui.exploration.MapActivity" />
        <activity android:name=".ui.profile.ProfileActivity" />
        <activity android:name=".ui.events.EvenementsActivity" />
    </application>

</manifest>
